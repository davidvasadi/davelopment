{
  "kind": "singleType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "/services"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "heading": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "sub_heading": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "seo": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.seo",
      "repeatable": false
    },
    "dynamic_zone": {
      "type": "dynamiczone",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "components": [
        "dynamic-zone.why-choose-us",
        "dynamic-zone.testimonials",
        "dynamic-zone.services",
        "dynamic-zone.related-products",
        "dynamic-zone.related-articles",
        "dynamic-zone.products",
        "dynamic-zone.pricing",
        "dynamic-zone.newsletter",
        "dynamic-zone.launches",
        "dynamic-zone.how-it-works",
        "dynamic-zone.hero",
        "dynamic-zone.form-next-to-section",
        "dynamic-zone.features",
        "dynamic-zone.faq",
        "dynamic-zone.cta",
        "dynamic-zone.brands",
        "dynamic-zone.blog"
      ]
    },
    "pages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::page.page"
    },
    "cta": {
      "type": "dynamiczone",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "components": [
        "dynamic-zone.why-choose-us",
        "dynamic-zone.testimonials",
        "dynamic-zone.services",
        "dynamic-zone.related-products",
        "dynamic-zone.related-articles",
        "dynamic-zone.products",
        "dynamic-zone.pricing",
        "dynamic-zone.newsletter",
        "dynamic-zone.launches",
        "dynamic-zone.how-it-works",
        "dynamic-zone.hero",
        "dynamic-zone.form-next-to-section",
        "dynamic-zone.features",
        "dynamic-zone.faq",
        "dynamic-zone.cta",
        "dynamic-zone.brands",
        "dynamic-zone.blog"
      ]
    }
  }
}
