{
  "name": "structured-data-generator",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-server": {
      "source": "./strapi-server.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch"
  },
  "devDependencies": {
    "@strapi/sdk-plugin": "5.2.6",
    "@strapi/strapi": "^5.40.0"
  },
  "strapi": {
    "name": "structured-data-generator",
    "displayName": "Structured Data Generator",
    "description": "Auto-generates schema.org JSON-LD structured data",
    "kind": "plugin"
  },
  "dependencies": {
    "@strapi/admin": "^5.40.0"
  }
}
