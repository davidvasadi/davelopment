    "@payloadcms/ui": "^3.80.0",
    "@tailwindcss/postcss": "^4.2.2",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "framer-motion": "^12.38.0",
    "graphql": "^16.9.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "payload": "^3.43.0",
    "react": "^19.1.0",
